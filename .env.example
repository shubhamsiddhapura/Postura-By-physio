# ---------------------------------------------------------------------------
# Supabase + Prisma configuration
#
# Copy this file to `.env` at the repo root and fill in real values.
# `.env` is git-ignored. NEVER commit real secrets here.
# ---------------------------------------------------------------------------


# ---- Database (Prisma) ----------------------------------------------------
# Get both URLs from:
#   Dashboard -> Project Settings -> Database -> Connection string
#
# DATABASE_URL = "Transaction pooler" URL (port 6543). Used at RUNTIME.
# DIRECT_URL   = "Direct connection"  URL (port 5432). Used by migrations.
# Both URLs embed your database password. If you don't remember it, click
# "Reset database password" on that page and recopy the strings.
#
# KEEP the `?pgbouncer=true&connection_limit=1` on DATABASE_URL.

DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"


# ---- Supabase JS client (server / future use) -----------------------------
# These aren't needed for the Blog CRUD APIs today (Prisma handles that),
# but they're wired up in lib/supabase.ts for future use:
# Storage uploads, Auth admin, Realtime, etc.

NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Publishable (browser-safe) key. Starts with `sb_publishable_...`.
# Project Settings -> API Keys -> "Publishable and secret API keys" tab.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_<REPLACE_ME>"

# Secret (server-only) key. Starts with `sb_secret_...`.
# SERVER ONLY. Bypasses RLS. NEVER expose this to the browser.
SUPABASE_SECRET_KEY="sb_secret_<REPLACE_ME>"


# ---- Apps -----------------------------------------------------------------
# Base URL the admin dashboard uses to talk to the web API.
# Local dev: web runs on :3000, admin on :3001.
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"


# ---- Internal admin → web (testimonial invite email) ----------------------
# Long random string, identical on the admin app and the web app. The admin
# dashboard proxies invite requests to POST /api/internal/testimonials/send-share-invite
# on the web API using Authorization: Bearer <this value>.
ADMIN_INTERNAL_API_SECRET=""

# Full URL of the public Share Your Story testimonial form (served by the web app).
# If unset, the server defaults to https://www.posturabyphysio.com/share-your-story
# SHARE_STORY_FORM_URL="https://www.posturabyphysio.com/share-your-story"


# ---- Email (nodemailer SMTP) ----------------------------------------------
# Used by POST /api/bookings, /api/contact, internal testimonial invite, etc.
# If any of SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASSWORD is missing,
# mail is skipped (logged to the server console). Bookings still succeed.
#
# Tested providers:
#   - Gmail app password:  host=smtp.gmail.com  port=587  user=<you>@gmail.com
#   - Resend:              host=smtp.resend.com port=465  user=resend  pass=<api-key>
#   - SendGrid:            host=smtp.sendgrid.net port=587 user=apikey  pass=<api-key>
#   - Mailgun / SES / any generic SMTP

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
# Leave SMTP_SECURE unset to auto-detect (true when port=465). Set "true"/"false" to override.
# SMTP_SECURE=""

# DEV ONLY — skip TLS certificate verification. Use this if your local
# machine's antivirus / corporate proxy does TLS interception and nodemailer
# fails with "self-signed certificate in certificate chain". NEVER enable
# in production — the connection becomes MITM-able.
# SMTP_TLS_INSECURE="true"

# From header displayed to recipients. Format: "Name <email@example.com>".
MAIL_FROM="Postura by Physio <bookings@example.com>"

# Where the admin notification goes. Defaults to MAIL_FROM if unset.
BOOKINGS_NOTIFY_EMAIL=""


# ---- WhatsApp notifications (CallMeBot) -----------------------------------
# Free service that sends WhatsApp messages to a personal number.
# Used by POST /api/contact to silently notify the doctor on every enquiry.
# If either var is missing the WhatsApp step is skipped (email still works).
#
# One-time setup (doctor does this once on their phone):
#   1. Save the number  +34 644 59 77 39  as a WhatsApp contact.
#   2. Send it the message:  I allow callmebot to send me messages
#   3. You'll receive an API key — paste it below as CALLMEBOT_WHATSAPP_APIKEY.
#
# Docs: https://www.callmebot.com/blog/free-api-whatsapp-messages/

# Doctor's WhatsApp number with country code, no + sign (e.g. 916354011290)
CALLMEBOT_WHATSAPP_PHONE="916354011290"
CALLMEBOT_WHATSAPP_APIKEY=""
