#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
fi
# cmd-shim-target=/Users/yashprajapati/Projects/Postura-By-physio/.pnpm-store/v11/links/@/pnpm/10.29.2/11ae9dafa50115d6204e022dce9a63f2c06edfa627943cc1f80fd3f4924d7c30/node_modules/pnpm/bin/pnpx.cjs
