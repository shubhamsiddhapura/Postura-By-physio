generator client {
  provider = "prisma-client-js"
  // "native" builds the engine for your local OS (Windows here); the RHEL
  // target is required for Vercel/AWS Lambda serverless runtimes. Without
  // it, Prisma crashes on cold start in production with no helpful body.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Blog {
  id          String    @id @default(cuid())
  slug        String    @unique

  // --- Hero (required) ---
  title     String
  eyebrow   String
  excerpt   String
  imageSrc  String
  author    String    @default("Dr. Priyanshi Pandya")
  tags      String[]  @default([])
  published Boolean   @default(false)
  publishedAt DateTime?

  // --- Introduction section (required) ---
  introEyebrow      String
  introTitle        String
  introDescription  String
  introDescription2 String?
  introImageSrc     String
  introImageAlt     String?

  // --- Causes section (optional) ---
  // `causesItems` is a JSON array of { title, description, icon }
  causesEyebrow     String?
  causesTitle       String?
  causesDescription String?
  causesColumns     Int?
  causesItems       Json?

  // --- Symptoms section (required) ---
  symptomsEyebrow     String
  symptomsTitle       String
  symptomsDescription String
  symptomsBullets     String[] @default([])
  symptomsImageSrc    String
  symptomsImageAlt    String?
  symptomsFlipImage   Boolean  @default(false)

  // --- Solutions section (optional) ---
  // `solutionsItems` is a JSON array of { title, description, icon }
  solutionsEyebrow     String?
  solutionsTitle       String?
  solutionsDescription String?
  solutionsItems       Json?

  // --- Conclusion section (optional) ---
  conclusionTitle      String?
  conclusionParagraphs String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, publishedAt])
  @@map("blogs")
}

model Testimonial {
  id        String   @id @default(cuid())
  tag       String
  quote     String
  name      String
  age       Int
  avatar    String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, order])
  @@map("testimonials")
}

model GalleryImage {
  id        String          @id @default(cuid())
  url       String
  alt       String
  category  GalleryCategory
  order     Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([category, order])
  @@map("gallery_images")
}

enum GalleryCategory {
  physiotherapy
  aerobics
  yoga
  pilates
  corporate

  @@map("gallery_category")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  icon        String?
  image       String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

/// Appointment request from the public site.
///
/// Created by POST /api/bookings from either:
///   - /book-a-session directly, or
///   - /patient-interaction -> confirm -> /book-a-session
/// When coming from the patient-interaction flow the optional profile*,
/// activityLevel, discomfortArea, and possibleCause fields are filled
/// from the on-page questionnaire.
model Booking {
  id                String         @id @default(cuid())

  // --- Program selection + contact ---
  program           BookingProgram
  fullName          String
  phone             String
  email             String
  preferredDateTime String // Free-form text produced by BookingDateTimeField ("Apr 20, 2026, 10:00 AM")

  // Optional on the public form
  consultationType  String? // "Home visit" | "Online" | "Phone" | "Society / group" | null
  address           String?
  message           String?

  // --- Optional questionnaire answers (only set if user came from /patient-interaction) ---
  profileAbout      String? // e.g. "IT / Software Professional"
  activityLevel     String? // e.g. "6 - 8 hours sitting"
  discomfortArea    String? // e.g. "Lower Back"
  possibleCause     String? // e.g. "Prolonged sitting / Poor posture"

  // --- Admin workflow ---
  status            BookingStatus  @default(pending)
  notes             String? // admin-only internal notes

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([status, createdAt])
  @@map("bookings")
}

enum BookingProgram {
  physiotherapy
  fitness

  @@map("booking_program")
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled

  @@map("booking_status")
}

/// Weekly availability template. One row per (dayOfWeek x time) slot the
/// clinic is willing to offer. Absence of a row for a given day = no
/// bookings accepted that day. Queried by the public booking calendar and
/// edited in the admin "Availability" tab.
model AvailabilitySlot {
  id        String @id @default(cuid())
  dayOfWeek Int // 0 = Sunday ... 6 = Saturday (matches JS Date.getDay())
  time      String // Display string, e.g. "10:00 AM" — shown verbatim to customers
  sortKey   Int // Minutes-of-day (e.g. 600 for 10:00 AM) for chronological sort

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek, time])
  @@index([dayOfWeek, sortKey])
  @@map("availability_slots")
}

/// Specific dates blocked entirely (public holidays, clinic closure,
/// personal leave). Overrides the weekly template.
model BlockedDate {
  id     String   @id @default(cuid())
  date   DateTime @unique @db.Date
  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blocked_dates")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  @@map("admin_users")
}
